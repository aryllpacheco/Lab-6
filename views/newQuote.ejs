<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add new Quote</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body>

    <header>
        <%- include('partials/header.ejs') %>
    </header> 

    <br>

    <form action="/newQuote" method="post">
        <label for="quoteInput">Add a new quote to database:</label>
        <input id="quoteInput" name="quote">
        <br>

        <label for="authorInput">Author</label>
        <select name="authorId" id="authorId">
            <option value="1">Albert Einstein</option>
            <option value="2">Agatha Christie</option>
            <option value="3">Marie Curie</option>
            <option value="8">Robin Hobb</option>
        </select>

        <button>Submit</button>
    </form>

    <script src="/js/newQuote.js"></script>

    <br><br><br>

    <footer>
        <%- include('partials/footer.ejs') %>
    </footer>

</body>
</html>