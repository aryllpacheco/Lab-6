<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lab 6 : Quote Finder</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>

<body>

    <header>
        <%- include('partials/header.ejs') %>
    </header>

    <h1> Quote Finder </h1>

    <nav> <a href="/"> Home </a> </nav>

    <form id="searchByKeywordForm" action="/searchByKeyword" method="get">
        Keyword: <input type="text" name="keyword">
        <button> Search By Keyword</button>
    </form> <br> 

    <form action="/searchByAuthor" method="get">
        Author:
        <select name="authorId">
            <% for(let i of authors) {%>
                <option value="<%= i.authorId %>">
                    <%= i.firstName %>
                        <%= i.lastName %>
                </option>
                <% } %>
        </select>
        <button> Search By Authors</button>
    </form>

    <br>

    <form action="/searchByCategory" method="get">
        Category:
        <select name="categories">
            <% for(let i of categories) {%>
                <option value="<%= i.category %>">
                    <%= i.firstName %>
                        <%= i.lastName %>
                </option>
                <% } %>
        </select>
        <button> Search By Categories</button>
    </form>

    <br>

    <form action="/addAuthor" method="post">
        Add Author: <br>
        First Name: <input type="text" name="firstName"> <br>
        Last Name: <input type="text" name="lastName"> <br>
        Date of Birth: <input type="date" name="dob"> <br>
        Date of Death: <input type="date" name="dod"> <br>
        Sex: <br>
        <input type="radio" value="F" name="sex"> Female <br>
        <input type="radio" value="M" name="sex"> Male <br>
        Profession: <input type="text" name="profession"> <br>
        Country: <input type="text" name="country"> <br>
        Picture: <input type="text" name="portrait"> <br>
        Biography: <input type="text" name="biography"> <br>
        <button>Submit</button>
    </form>
    
    <br>

    <a href="/newQuote"> Add new Quote</a>

    <script src="/js/home.js"></script>

    <br><br><br>

    <footer>
        <%- include('partials/footer.ejs') %>
    </footer>

</body>

</html>